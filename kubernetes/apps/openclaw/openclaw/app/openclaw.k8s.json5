// OpenClaw config — Kubernetes variant of "Kev's Dream Team".
// Differences from the local ../openclaw.json:
//   * workspace paths are absolute container paths (/home/node/.openclaw/...), not ~
//   * sandbox backend is "openshell" (Docker-out-of-Docker doesn't fit K8s)
//   * onboarding is skipped; provider creds + Discord come from env (k8s Secret)
//
// Mounted read-only at /etc/openclaw/openclaw.json; the Gateway reads it via
// OPENCLAW_CONFIG_PATH (set in deployment.yaml). Validate: openclaw doctor --fix
{
  gateway: {
    mode: "local",                  // required: self-hosted single gateway
    // bind stays "loopback" (default): no gateway auth needed. Probes hit 127.0.0.1
    // via exec, port-forward connects to pod-localhost, Discord is outbound. Nothing
    // needs the gateway on 0.0.0.0. (To expose via Service/Ingress later, set bind:"lan"
    // AND gateway.auth.token.)
    port: 18789,
    reload: { mode: "hybrid", debounceMs: 300 },
  },

  agents: {
    defaults: {
      workspace: "/home/node/.openclaw/workspaces/kev",
      model: {
        primary: "openai/gpt-5.4",
        fallbacks: ["openai/gpt-5.4-mini"],
      },
      models: {
        "openai/gpt-5.4":        { alias: "GPT5" },
        "openai/gpt-5.4-mini":   { alias: "Mini" },
        "openai/gpt-5.2-codex":  { alias: "Codex" },
      },
      // Sandboxing via OpenShell-managed remote environments (not local Docker).
      sandbox: {
        mode: "non-main",      // off | non-main | all
        backend: "openshell",
        scope: "session",
        workspaceAccess: "rw",
      },
      subagents: {
        maxSpawnDepth: 2,
        maxChildrenPerAgent: 5,
        maxConcurrent: 8,
        runTimeoutSeconds: 900,
      },
    },

    list: [
      {
        id: "kev",
        default: true,
        workspace: "/home/node/.openclaw/workspaces/kev",
        model: { primary: "openai/gpt-5.4" },
        sandbox: { mode: "off" },              // orchestrator runs in the gateway pod
        tools: {
          profile: "messaging",
          alsoAllow: [
            "sessions_spawn", "sessions_yield", "subagents",
            "sessions_list", "sessions_history",
          ],
        },
        heartbeat: {
          every: "30m",
          target: "last",
          lightContext: true,
          isolatedSession: true,
          skipWhenBusy: true,
          activeHours: { start: "08:00", end: "22:00", timezone: "America/New_York" },
          prompt: "Scan MEMORY.md and open GitHub items for anything needing action. Reply HEARTBEAT_OK if nothing urgent.",
        },
      },
      {
        id: "rex",
        workspace: "/home/node/.openclaw/workspaces/rex",
        model: { primary: "openai/gpt-5.2-codex" },
        sandbox: { mode: "all", backend: "openshell", scope: "session", workspaceAccess: "rw" },
        skills: ["github"],
      },
      {
        id: "scout",
        workspace: "/home/node/.openclaw/workspaces/scout",
        model: { primary: "openai/gpt-5.4-mini" },
        sandbox: { mode: "non-main", backend: "openshell", workspaceAccess: "ro" },
        skills: ["web", "weather"],
      },
      {
        id: "hawk",
        workspace: "/home/node/.openclaw/workspaces/hawk",
        model: { primary: "openai/gpt-5.4" },
        sandbox: { mode: "non-main", backend: "openshell", workspaceAccess: "ro" },
      },
      {
        id: "dash",
        workspace: "/home/node/.openclaw/workspaces/dash",
        model: { primary: "openai/gpt-5.4" },
        sandbox: { mode: "non-main", backend: "openshell", workspaceAccess: "rw" },
      },
      {
        id: "dot",
        workspace: "/home/node/.openclaw/workspaces/dot",
        model: { primary: "openai/gpt-5.4" },
        sandbox: { mode: "non-main", backend: "openshell", workspaceAccess: "rw" },
        skills: ["github"],
      },
      {
        id: "pixel",
        workspace: "/home/node/.openclaw/workspaces/pixel",
        model: { primary: "openai/gpt-5.4" },  // vision-capable; no image gen configured
        sandbox: { mode: "non-main", backend: "openshell", workspaceAccess: "rw" },
      },
    ],
  },

  // OpenShell sandbox plugin → self-hosted OpenShell gateway in-cluster
  // (deployed via cluster-template: apps/openshell, chart 0.0.42).
  // TLS is disabled on that gateway, so the endpoint is http:// not https://.
  plugins: {
    // NOTE: don't set plugins.allow — it restricts to ONLY listed ids and drops bundled
    // plugins (codex, etc). Empty allow = bundled load + discovered plugins auto-load.
    entries: {
      discord: { enabled: true },      // activate the @openclaw/discord channel plugin
      openshell: {
        enabled: true,
        config: {
          from: "openclaw",
          mode: "remote",                 // mirror | remote
          command: "openshell",
          gatewayEndpoint: "http://openshell.openshell.svc.cluster.local:8080",
          policy: "strict",
          remoteWorkspaceDir: "/sandbox",
          remoteAgentWorkspaceDir: "/agent",
          timeoutSeconds: 120,
        },
      },
    },
  },

  channels: {
    discord: {
      enabled: true,
      token: "${DISCORD_BOT_TOKEN}",   // env interpolation (proven to work for hooks.token)
      dmPolicy: "allowlist",
      allowFrom: ["discord:177166264496685060"],   // channel-prefixed peer id (bare id didn't match)
      groupPolicy: "allowlist",
      // Privileged intents (Message Content, Server Members) are enabled in the
      // Discord Developer Portal, not here — the config schema doesn't take them.
      guilds: {
        // Guild (server) ID — can't be env-interpolated as a map key, so it's inline.
        // Not secret. Verify this matches your server ID if guild replies don't work.
        "1511202661213667300": {
          requireMention: true,
          users: ["177166264496685060"],
        },
      },
    },
  },

  bindings: [
    { agentId: "kev", match: { channel: "discord" } },
  ],

  session: {
    dmScope: "per-channel-peer",
    threadBindings: { enabled: true, idleHours: 24 },
    reset: { mode: "daily", atHour: 4, idleMinutes: 120 },
  },

  hooks: {
    enabled: true,
    path: "/hooks",
    token: "${OPENCLAW_HOOK_TOKEN}",
    mappings: [
      { match: { path: "github" }, action: "agent", agentId: "kev", deliver: true },
      { match: { path: "alert" },  action: "agent", agentId: "kev", deliver: true },
    ],
  },

  cron: {
    enabled: true,
    maxConcurrentRuns: 8,
    sessionRetention: "24h",
  },
}
